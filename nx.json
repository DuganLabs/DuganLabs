{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "worker": [
      "{projectRoot}/index.js",
      "{projectRoot}/wrangler.toml"
    ],
    "pages": [
      "{projectRoot}/**/*.html",
      "{projectRoot}/css/**/*.css",
      "{projectRoot}/js/**/*.js",
      "{projectRoot}/vendor/**/*"
    ]
  }
}
