{
  "name": "worker",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "dev": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec wrangler dev",
        "cwd": "worker"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec wrangler deploy",
        "cwd": "worker"
      }
    }
  }
}
